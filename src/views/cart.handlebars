<main class="container container--wide" data-cart-id="{{cartId}}">
  <header class="page-header">
    <h1>Mi carrito</h1>
    <p class="subtitle mono">ID: {{cartId}}</p>
  </header>

  {{#if isEmpty}}
    <p class="empty">El carrito está vacío. <a class="link" href="/products">Ver productos</a></p>
  {{else}}
    <ul class="cart-list">
      {{#each items}}
        <li class="cart-item" data-product-id="{{product._id}}">
          <div>
            <h2><a class="product-title" href="/products/{{product._id}}">{{product.title}}</a></h2>
            <span class="meta">{{money product.price}} c/u · Categoría: {{product.category}}</span>
          </div>

          <div class="cart-controls">
            <input
              class="qty-input"
              type="number"
              min="1"
              value="{{quantity}}"
              aria-label="Cantidad"
            />
            <button class="btn btn--ghost update-qty">Actualizar</button>
            <span class="subtotal">{{money subtotal}}</span>
            <button class="btn btn--danger remove-item">Eliminar</button>
          </div>
        </li>
      {{/each}}
    </ul>

    <footer class="cart-footer">
      <p class="total">Total: <strong>{{money total}}</strong></p>
      <button class="btn btn--danger" id="clear-cart">Vaciar carrito</button>
    </footer>
  {{/if}}
</main>
